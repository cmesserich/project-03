DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
ANTHROPIC_API_KEY=

# Comma-separated CIDRs allowed to access /admin routes
# Example: 192.168.68.0/24,10.0.0.1/32
# Use 0.0.0.0/0 to allow all IPs (rely on is_admin flag only)
ADMIN_ALLOWED_NETWORKS=0.0.0.0/0

# Stripe — get these from dashboard.stripe.com
# Test keys start with sk_test_ / whsec_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Report price in cents (900 = $9.00)
REPORT_PRICE_CENTS=900

# Public base URL of the app — used for Stripe redirect URLs
# No trailing slash. Example: https://touchgrass.design
APP_BASE_URL=http://localhost:8003